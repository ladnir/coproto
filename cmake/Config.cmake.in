# compile the library logging support
set(COPROTO_LOGGING @COPROTO_LOGGING@) 
set(coproto_LOGGING @COPROTO_LOGGING@) 

include("${CMAKE_CURRENT_LIST_DIR}/coprotoFindDeps.cmake")